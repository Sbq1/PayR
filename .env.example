# Supabase Database
# DATABASE_URL: pooler transaccional (port 6543) — runtime de la app.
#   Role con permisos limitados (payr_prod o equivalente).
# DIRECT_URL: session pooler (port 5432) — tools que requieren conexión
#   estable (Prisma Studio, scripts TSX). Mismo role que DATABASE_URL.
# MIGRATION_URL: session pooler con role postgres (superuser) — SOLO para
#   `prisma migrate`. Los roles limitados no pueden CREATE TABLE / ALTER
#   TYPE. Principio de mínimo privilegio en runtime.
DATABASE_URL="postgresql://payr_prod.lqzavblwjfonjhkieckb:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://payr_prod.lqzavblwjfonjhkieckb:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
MIGRATION_URL="postgresql://postgres.lqzavblwjfonjhkieckb:[YOUR-DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Auth
# AUTH_SECRET: firma JWT staff + comensal. Generar con:
#   openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# QR HMAC signing secret (Fase 1 — servidor-only)
# Firma el token HMAC de cada QR físico. Mínimo 32 chars.
# Generar con: openssl rand -hex 32
# Rotar vía docs/runbooks/qr-secret-rotation.md (fase 5) con ventana dual.
QR_SECRET="generate-with-openssl-rand-hex-32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encryption (for stored credentials)
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Upstash Redis (rate limiting — provisioned via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry (optional — error tracking)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Siigo (per-restaurant, stored encrypted in DB)
# These are only needed for testing
# SIIGO_USERNAME=""
# SIIGO_ACCESS_KEY=""

# Wompi (per-restaurant, stored encrypted in DB)
# These are only needed for testing
# WOMPI_PUBLIC_KEY=""
# WOMPI_PRIVATE_KEY=""
# WOMPI_EVENTS_SECRET=""
# WOMPI_INTEGRITY_SECRET=""
