generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                  String?
  email                 String               @unique
  email_verified        DateTime?            @db.Timestamptz(6)
  password_hash         String?
  image                 String?
  session_version       Int                  @default(0)
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @default(now()) @db.Timestamptz(6)
  restaurants           Restaurant[]
  cancelled_orders      Order[]              @relation("OrderCancelledBy")
  password_reset_tokens PasswordResetToken[]
  auth_events           AuthEvent[]
  initiated_refunds     Refund[]

  @@map("users")
}

model PasswordResetToken {
  token      String    @id
  user_id    String
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_password_reset_tokens_user")
  @@map("password_reset_tokens")
}

model AuthEvent {
  id         String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  user_id    String?
  email      String?
  event_type auth_event_type
  ip         String?
  user_agent String?
  metadata   Json?
  created_at DateTime         @default(now()) @db.Timestamptz(6)
  user       User?            @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at], map: "idx_auth_events_user")
  @@index([email, created_at], map: "idx_auth_events_email")
  @@index([event_type, created_at], map: "idx_auth_events_event_type")
  @@map("auth_events")
}


model SubscriptionPlan {
  id                 String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  tier               plan_tier    @unique
  name               String
  max_tables         Int
  monthly_price_cop  Int
  allow_split_bill   Boolean      @default(false)
  allow_upsell       Boolean      @default(false)
  allow_analytics    Boolean      @default(false)
  allow_custom_theme Boolean      @default(false)
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @db.Timestamptz(6)
  restaurants        Restaurant[]

  @@map("subscription_plans")
}

model Restaurant {
  id                     String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                   String
  slug                   String           @unique
  owner_id               String
  plan_id                String
  logo_url               String?
  primary_color          String           @default("#6366f1")
  secondary_color        String           @default("#f59e0b")
  background_color       String           @default("#ffffff")
  custom_theme           Json?
  pos_provider           String           @default("siigo")
  siigo_username         String?
  siigo_access_key       String?
  wompi_public_key       String?
  wompi_private_key      String?
  wompi_events_secret    String?
  wompi_integrity_secret String?
  qr_dark_color          String           @default("#000000")
  qr_light_color         String           @default("#ffffff")
  qr_error_correction    String           @default("M")
  qr_logo_data           Bytes?
  qr_logo_mime           String?
  qr_frame_style         String           @default("none")
  fe_regime              fe_regime        @default(OPTIONAL)
  is_active              Boolean          @default(true)
  created_at             DateTime         @default(now()) @db.Timestamptz(6)
  updated_at             DateTime         @default(now()) @db.Timestamptz(6)
  orders                 Order[]
  users                  User             @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subscription_plans     SubscriptionPlan @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tables                 Table[]
  upsell_products        UpsellProduct[]
  sessions               Session[]

  @@index([slug], map: "idx_restaurants_slug")
  @@map("restaurants")
}

model Table {
  id                   String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  restaurant_id        String
  table_number         Int
  label                String?
  siigo_cost_center_id String?
  status               table_status @default(AVAILABLE)
  is_active            Boolean      @default(true)
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @db.Timestamptz(6)
  orders               Order[]
  qr_codes             QrCode?
  restaurants          Restaurant   @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sessions             Session[]

  @@unique([restaurant_id, table_number])
  @@map("tables")
}

model QrCode {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  table_id      String   @unique
  url           String   @unique
  is_active     Boolean  @default(true)
  token_version Int      @default(1)
  rotated_at    DateTime @default(now()) @db.Timestamptz(6)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  tables        Table    @relation(fields: [table_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("qr_codes")
}

model Order {
  id                    String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  restaurant_id         String
  table_id              String
  siigo_invoice_id      String?
  subtotal              Int
  tax                   Int          @default(0)
  tip_amount            Int          @default(0)
  tip_percentage        Float?
  total                 Int
  customer_count        Int          @default(1)
  status                order_status @default(PENDING)
  version               Int          @default(0)
  locked_at             DateTime?    @db.Timestamptz(6)
  lock_expires_at       DateTime?    @db.Timestamptz(6)
  locked_by_session_id  String?
  cancelled_by_user_id  String?
  cancelled_at          DateTime?    @db.Timestamptz(6)
  created_at            DateTime     @default(now()) @db.Timestamptz(6)
  updated_at            DateTime     @default(now()) @db.Timestamptz(6)
  order_items           OrderItem[]
  restaurants           Restaurant   @relation(fields: [restaurant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tables                Table        @relation(fields: [table_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cancelled_by          User?        @relation("OrderCancelledBy", fields: [cancelled_by_user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  locked_by_session     Session?     @relation("OrderLockedBySession", fields: [locked_by_session_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  payments              Payment[]

  @@index([restaurant_id, created_at], map: "idx_orders_restaurant_date")
  @@index([table_id], map: "idx_orders_table")
  @@index([cancelled_by_user_id], map: "idx_orders_cancelled_by")
  @@map("orders")
}

model OrderItem {
  id               String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  order_id         String
  siigo_product_id String?
  name             String
  quantity         Int
  unit_price       Int
  total_price      Int
  is_upsell        Boolean @default(false)
  orders           Order   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order")
  @@map("order_items")
}

model Payment {
  id                           String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  order_id                     String
  wompi_transaction_id         String?        @unique
  reference                    String         @unique
  amount_in_cents              Int
  currency                     String         @default("COP")
  status                       payment_status @default(PENDING)
  payment_method_type          String?
  customer_email               String?
  wompi_response               Json?
  tip_amount                   Int            @default(0)
  tip_percentage               Decimal?       @db.Decimal(5, 2)
  tip_disclaimer_accepted_at   DateTime?      @db.Timestamptz(6)
  tip_disclaimer_text_version  String?
  customer_document_type       String?
  customer_document_number     String?
  dian_doc_type                String?
  refunded_amount              Int            @default(0)
  created_at                   DateTime       @default(now()) @db.Timestamptz(6)
  paid_at                      DateTime?      @db.Timestamptz(6)
  orders                       Order          @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sessions                     Session[]
  refunds                      Refund[]

  @@index([order_id], map: "idx_payments_order")
  @@index([reference], map: "idx_payments_reference")
  @@index([wompi_transaction_id], map: "idx_payments_wompi_txn")
  @@map("payments")
}

model UpsellProduct {
  id            String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  restaurant_id String
  name          String
  description   String?
  price         Int
  image_url     String?
  is_active     Boolean    @default(true)
  sort_order    Int        @default(0)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @db.Timestamptz(6)
  restaurants   Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([restaurant_id], map: "idx_upsell_products_restaurant")
  @@map("upsell_products")
}

enum order_status {
  PENDING
  PAYING
  PAID
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum payment_status {
  PENDING
  APPROVED
  DECLINED
  VOIDED
  ERROR
  REFUNDED
  PARTIALLY_REFUNDED
}

enum plan_tier {
  STARTER
  PRO
  ENTERPRISE
}

enum table_status {
  AVAILABLE
  OCCUPIED
  PAYING
}

/// Régimen de Factura Electrónica DIAN del restaurante.
/// - MANDATORY: total >= 5 UVT exige customer_document → dian_doc_type='E_INVOICE'
/// - OPTIONAL:  documento equivalente POS siempre; FE bajo solicitud
/// - EXEMPT:    no emite FE bajo ningún monto
enum fe_regime {
  MANDATORY
  OPTIONAL
  EXEMPT
}

enum auth_event_type {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  SESSION_REFRESHED
}

model ProcessedWebhook {
  event_id     String    @id // compuesto: "{transaction.id}:{status}"
  event_type   String
  received_at  DateTime  @default(now()) @db.Timestamptz(6)
  processed_at DateTime? @db.Timestamptz(6)
  metadata     Json?

  @@index([received_at], map: "idx_processed_webhooks_received")
  @@map("processed_webhooks")
}

/// Parámetros tributarios DIAN actualizables por año.
/// Fuente de verdad del UVT para la lógica del 5 UVT (documento POS vs FE).
/// Se actualiza anualmente por Resolución DIAN — script `seed-tax-parameters`
/// inserta el año siguiente antes del 1 de enero.
model TaxParameter {
  year              Int      @id
  uvt_cop           Int
  source_resolution String?
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@map("tax_parameters")
}

/// Sesión efímera del comensal post-escaneo QR.
/// Emitida por POST /api/session/start. TTL 2h, hash del JWT en token_hash
/// para revocación vía revoked_at sin invalidar la firma.
/// scope 'table' = operación normal; 'receipt' = post-pago, ver comprobante.
model Session {
  id            String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  table_id      String
  restaurant_id String
  token_hash    String    @unique
  scope         String    @default("table") // 'table' | 'receipt'
  payment_id    String?
  user_agent    String?
  ip            String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  expires_at    DateTime  @db.Timestamptz(6)
  revoked_at    DateTime? @db.Timestamptz(6)

  tables        Table      @relation(fields: [table_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  restaurants   Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payments      Payment?   @relation(fields: [payment_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  locked_orders Order[]    @relation("OrderLockedBySession")

  @@index([expires_at], map: "idx_sessions_expires")
  @@index([table_id, expires_at], map: "idx_sessions_table")
  @@map("sessions")
}

/// Header HTTP Idempotency-Key. PK compuesto (key, session_id, endpoint).
/// `session_id` es un SCOPE genérico (sesión efímera del comensal para
/// endpoints /api/..., o user.id del staff para endpoints del dashboard).
/// Sin FK: las sesiones de comensal tienen TTL 2h y los users no se
/// borran; el cron expire-sessions purga por expires_at (Fase 4).
model IdempotencyKey {
  key             String
  session_id      String
  endpoint        String
  request_hash    String
  response_status Int?
  response_body   Json?
  locked_at       DateTime  @default(now()) @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  expires_at      DateTime  @db.Timestamptz(6)

  @@id([key, session_id, endpoint])
  @@index([expires_at], map: "idx_idempotency_expires")
  @@map("idempotency_keys")
}

/// Skeleton v1: el staff del restaurante abre el modal de refund; este
/// endpoint crea el row con status='PENDING' y un humano procesa el
/// refund real en panel Wompi + nota crédito Siigo. Post-piloto (v2)
/// será automatizado. 3 capas anti-race: idempotency_key UNIQUE +
/// unique index de dedupe semántico + lock optimista en
/// payments.refunded_amount. Ver migración 8.
model Refund {
  id                   String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  payment_id           String
  amount_in_cents      Int
  reason               String
  reason_hash          String
  idempotency_key      String    @unique
  initiated_by         String
  status               String    @default("PENDING") // PENDING | APPROVED | FAILED
  wompi_refund_id      String?
  siigo_credit_note_id String?
  error_message        String?
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  processed_at         DateTime? @db.Timestamptz(6)

  payments Payment @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user     User    @relation(fields: [initiated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([payment_id], map: "idx_refunds_payment")
  @@index([status], map: "idx_refunds_status")
  @@map("refunds")
}
